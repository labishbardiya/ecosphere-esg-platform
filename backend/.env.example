# Database Configuration
# In docker-compose, this will default to: postgresql://postgres:postgres@db:5432/ecosphere_social
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecosphere_social

# Security & JWT
JWT_SECRET=supersecretjwtkeyforprodreplaceinproduction
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Background Worker & Redis
# In docker-compose, this will default to: redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# AWS S3 Storage Config (leave empty to fallback to local file system storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=ecosphere-social-proofs

# Logging
LOG_LEVEL=INFO

# PostgreSQL container config (for Docker Compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ecosphere_social
POSTGRES_PORT=5432
